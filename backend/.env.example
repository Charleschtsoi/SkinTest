# Copy to `.env` and adjust paths. Used only for local development.

ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,*
REQUIRE_API_KEY=false
MAX_UPLOAD_MB=10

# Vision models (disabled by default until skin weights are provided)
ENABLE_MODEL1=false
# MODEL1_PATH=models/best_resnet50_skintest.pth
# MODEL1_LABELS=Benign Nevus,Melanoma,Basal Cell Carcinoma

ENABLE_MODEL2_VISION_H5=false
# MODEL2_VISION_H5_PATH=models/resnet152v2_skin.h5
# MODEL2_VISION_LABELS=Benign Nevus,Melanoma,Basal Cell Carcinoma
# Optional: if set in production, backend will download this private object to MODEL2_VISION_H5_PATH at startup.
# MODEL2_VISION_H5_GCS_URI=gs://<your-private-bucket>/v1/resnet152v2_skin.h5

ENABLE_DENSENET121=false
# DENSENET121_PATH=models/best_densenet121_skintest.pth

ENABLE_MODEL4_SWINT=false
# MODEL4_SWINT_PATH=models/best_swin_t_skin.pth
# MODEL4_SWINT_LABELS=Benign Nevus,Melanoma,Basal Cell Carcinoma,Actinic Keratosis,Seborrheic Keratosis,Vascular Lesion

ENABLE_MODEL5_DENSENET=false
# MODEL5_DENSENET_PATH=models/best_densenet121_skin.h5

# Gemini synthesis (optional server key)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
